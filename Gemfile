# Local preview only — GitHub Pages builds the site server-side.
# Run: bundle install && bundle exec jekyll serve
source "https://rubygems.org"

# The github-pages gem pins Jekyll + plugins to exactly what GitHub Pages runs,
# so a local build matches production.
gem "github-pages", group: :jekyll_plugins
gem "jekyll-remote-theme"

# Windows / JRuby extras (harmless elsewhere)
gem "webrick", "~> 1.8"
